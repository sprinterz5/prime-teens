generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: this schema covers only what the marketing/portal web app (apps/web)
// owns directly: portal login and the site's own lead capture. The full CRM
// domain (Deal, Contract, Payment, CuratorAssignment, Task, messaging, AI
// summaries) is designed in PLAN.md §6 and belongs to the future Spring Boot
// service (apps/api) — it is not modeled here to avoid two systems of record
// for the same tables.

enum Role {
  ADMIN
  SALES
  CURATOR
  PARENT
  STUDENT
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  ASSESSMENT_PAID
  ASSESSMENT_DONE
  PROPOSAL_SENT
  CONTRACT_SENT
  WON
  LOST
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?
  passwordHash String?
  oauthId      String?
  role         Role       @default(STUDENT)
  status       UserStatus @default(INVITED)
  locale       String     @default("ru")
  assignedLeads Lead[]    @relation("LeadAssignedSales")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  contact         String // phone or email
  role            String     @default("parent") // parent | student
  interest        String     @default("assessment") // assessment | consultation | program
  source          String     @default("site_form") // instagram | telegram_ads | site_form
  status          LeadStatus @default(NEW)
  consent         Boolean
  locale          String     @default("ru")
  assignedSalesId String?
  assignedSales   User?      @relation("LeadAssignedSales", fields: [assignedSalesId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
}
